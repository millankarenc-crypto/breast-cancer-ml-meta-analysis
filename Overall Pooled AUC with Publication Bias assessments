# =========================
# 7. Export results to Excel (MINIMAL VERSION)
# =========================

library(writexl)

# Create a simple dataframe with only essential results
simple_results <- data.frame(
  Test = c("Egger's Test", "Begg's Test"),
  P_Value = c(
    ifelse(is.null(egger_pvalue), NA, round(egger_pvalue, 4)),
    ifelse(is.null(begg_pvalue), NA, round(begg_pvalue, 4))
  ),
  Intercept_or_Tau = c(
    ifelse(is.null(egger_intercept), NA, round(egger_intercept, 4)),
    ifelse(is.null(begg_tau), NA, round(begg_tau, 4))
  ),
  Publication_Bias = c(
    ifelse(!is.null(egger_pvalue) && egger_pvalue < 0.05, "Yes", "No"),
    ifelse(!is.null(begg_pvalue) && begg_pvalue < 0.05, "Yes", "No")
  ),
  stringsAsFactors = FALSE
)

# Export to Excel
write_xlsx(list("Publication_Bias_Tests" = simple_results), 
           "publication_bias_results.xlsx")

cat("\n Publication bias results exported to 'publication_bias_results.xlsx'\n")
cat("\nExported results:\n")
